FROM python:3.12-slim

ARG CODEX_NPM_PACKAGE="@openai/codex"
ENV NPM_CONFIG_UPDATE_NOTIFIER=false

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates git nodejs npm tmux \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g "${CODEX_NPM_PACKAGE}" \
  && codex --version

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
COPY scripts ./scripts
COPY tests ./tests

RUN python -m pip install -e .

CMD ["python", "scripts/codex_task_integration.py", "--root", "/tmp/tmux-team-codex-itest", "--force"]
